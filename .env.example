# MinerU API Token（从 https://mineru.net/apiManage 获取）
MINERU_API_TOKEN=你的token

# API 来源：cloud / modal / agent
# cloud = MinerU 云端精准 API（默认，需 Token）
# modal = Modal 本地部署（L4 GPU）
# agent = MinerU Agent API（免登录，限制 10MB/20页）
MINERU_API_SOURCE=cloud

# Modal API Key（modal 模式需要，在 Modal 控制台创建 Secret）
MINERU_MODAL_API_KEY=你的modal_api_key
